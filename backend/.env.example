# ─────────────────────────────────────────────────────────────────────────────
# Reelify 2.0 — Environment Variables
# Copy this file to .env and fill in your values.
# ⚠️  NEVER commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ────────────────────────────────────────────────────────────────────
# Set to "true" ONLY for local development. NEVER set to true in production.
FLASK_DEBUG=false

# ── JWT Secret ───────────────────────────────────────────────────────────────
# REQUIRED in production. Must be a long, random, secret string.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret-string-at-least-32-chars

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Optional — app works in demo mode without it.
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── Google Gemini ─────────────────────────────────────────────────────────────
# Optional — used as primary AI. Falls back to OpenAI if missing.
# Get your key from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# ── Pexels ───────────────────────────────────────────────────────────────────
# Pexels — optional, for stock video FALLBACK (when FAL_KEY is not set)
PEXELS_API_KEY=your-pexels-api-key-here

# Pixabay — optional, stock video fallback after Pexels
PIXABAY_API_KEY=your-pixabay-api-key-here

# fal.ai — PRIMARY video generator (Wan 2.1 text-to-video)
# Get your key from: https://fal.ai/dashboard/keys  (~$0.05/sec)
FAL_KEY=your-fal-ai-api-key-here

# Jamendo — optional, for free background music search
# Get your free key from: https://developer.jamendo.com/v3/
JAMENDO_CLIENT_ID=your-jamendo-client-id-here

# ── Port (for local dev) ──────────────────────────────────────────────────────
# PORT=5000
